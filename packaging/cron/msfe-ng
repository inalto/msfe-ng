# MSFE-NG cron jobs (installed to /etc/cron.d/msfe-ng).
#
# Reconcile local domains + policy into MailScanner rule files every 10 minutes.
# `msfe-ng sync` is idempotent and reloads MailScanner only when something changed.
SHELL=/bin/sh
PATH=/usr/bin:/bin:/opt/msfe-ng/bin
*/10 * * * * root /opt/msfe-ng/bin/msfe-ng sync >/dev/null 2>&1
